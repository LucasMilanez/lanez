# ============================================
# Lanez frontend — Vite environment
# ============================================
# Copy to .env.local when you need non-default behavior.

# Backend target for the Vite dev proxy. Leave empty for the default
# (http://localhost:8000). Set to the Fly.io URL to run the SPA against
# production during local development.
# VITE_API_PROXY_TARGET=http://localhost:8000

# Absolute URL of the backend when running on a known public hostname.
# AuthContext uses this to redirect the OAuth flow directly to the backend
# (avoids Vercel proxy issues with 302 redirects).
# VITE_API_BASE_URL=https://lanez-app.fly.dev

# YouTube demo video URL rendered in the landing page. Leave empty to
# show the "video coming soon" placeholder.
# VITE_DEMO_VIDEO_URL=https://www.youtube.com/embed/xxxxxxxxxxx

# ------------------------------------------------------------
# Demo mode — for portfolio screenshots only
# ------------------------------------------------------------
# When true, the frontend serves synthetic fixture data instead of calling
# the backend. OAuth is skipped. A "DEMO DATA" badge appears in the bottom
# right corner. Never enable in a production build.
# VITE_DEMO_MODE=true
