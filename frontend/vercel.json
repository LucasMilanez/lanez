{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/auth/(.*)",       "destination": "https://lanez-app.fly.dev/auth/$1" },
    { "source": "/briefings/(.*)",  "destination": "https://lanez-app.fly.dev/briefings/$1" },
    { "source": "/briefings",       "destination": "https://lanez-app.fly.dev/briefings" },
    { "source": "/status/(.*)",     "destination": "https://lanez-app.fly.dev/status/$1" },
    { "source": "/status",          "destination": "https://lanez-app.fly.dev/status" },
    { "source": "/mcp/(.*)",        "destination": "https://lanez-app.fly.dev/mcp/$1" },
    { "source": "/voice/(.*)",      "destination": "https://lanez-app.fly.dev/voice/$1" },
    { "source": "/memories/(.*)",   "destination": "https://lanez-app.fly.dev/memories/$1" },
    { "source": "/memories",        "destination": "https://lanez-app.fly.dev/memories" },
    { "source": "/audit/(.*)",      "destination": "https://lanez-app.fly.dev/audit/$1" },
    { "source": "/audit",           "destination": "https://lanez-app.fly.dev/audit" },
    { "source": "/healthz",         "destination": "https://lanez-app.fly.dev/healthz" },
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ]
}
