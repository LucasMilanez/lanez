# ============================================
# Lanez — Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores.
# Variáveis sem valor padrão são OBRIGATÓRIAS.
#
# Hosts: em modo Compose os hosts são 'db', 'redis', 'searxng'.
#         Em modo manual (sem Docker) troque por 'localhost'.

# --- Microsoft Entra ID (OAuth 2.0) ---

# Application (client) ID registrado no Azure Portal
MICROSOFT_CLIENT_ID=

# Client secret gerado no Azure Portal
MICROSOFT_CLIENT_SECRET=

# Directory (tenant) ID do Azure AD
MICROSOFT_TENANT_ID=

# URL de callback OAuth
MICROSOFT_REDIRECT_URI=http://localhost:8000/auth/callback

# URL pública onde a Graph API entregará notificações de webhook
# Em dev local, deixa apontando pra localhost (subscriptions vão falhar,
# mas o app continua funcional para uso manual)
WEBHOOK_NOTIFICATION_URL=http://localhost:8000/webhooks/graph

# --- Segurança ---

# Gerar com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Segredo compartilhado para validação de notificações de webhook da Microsoft
WEBHOOK_CLIENT_STATE=

# --- Banco de Dados ---
# Em compose o host é 'db', em manual é 'localhost'
DATABASE_URL=postgresql+asyncpg://lanez:lanez@db:5432/lanez

# --- Redis ---
# Em compose o host é 'redis', em manual é 'localhost'
REDIS_URL=redis://redis:6379/0

# --- SearXNG ---
# Em compose o host é 'searxng', em manual é 'localhost'
SEARXNG_URL=http://searxng:8080

# --- CORS ---
CORS_ORIGINS=http://localhost:5173

# --- Anthropic API (Briefing — Fase 5) ---
# Obter em https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Briefing ---
BRIEFING_HISTORY_WINDOW_DAYS=90

# --- Groq Whisper (Voz — Fase 6b) ---
# Opcional — deixar vazio desabilita transcrição de voz
GROQ_API_KEY=
GROQ_WHISPER_MODEL=whisper-large-v3-turbo
VOICE_MAX_AUDIO_BYTES=5242880
VOICE_MAX_DURATION_SECONDS=30

# --- Audit Log (Fase 7) ---
AUDIT_HISTORY_WINDOW_DAYS=30

# ============================================
# Produção (Fly.io) — referência apenas
# ============================================
# As linhas abaixo NÃO são lidas pelo .env local.
# São referência de quais env vars precisam ser setadas no Fly.io
# via `fly secrets set NOME=valor` ou `flyctl secrets import < secrets.txt`.
#
# Não-secrets (já declaradas em fly.toml [env]):
#   BRIEFING_HISTORY_WINDOW_DAYS, AUDIT_HISTORY_WINDOW_DAYS,
#   GROQ_WHISPER_MODEL, VOICE_MAX_AUDIO_BYTES, VOICE_MAX_DURATION_SECONDS,
#   CORS_ORIGINS, MICROSOFT_REDIRECT_URI, WEBHOOK_NOTIFICATION_URL
#
# Secrets (precisam fly secrets set):
#   MICROSOFT_CLIENT_ID
#   MICROSOFT_CLIENT_SECRET
#   MICROSOFT_TENANT_ID
#   SECRET_KEY              ← gerar NOVA chave para prod (não reusar dev)
#   WEBHOOK_CLIENT_STATE    ← gerar NOVO valor para prod
#   DATABASE_URL            ← string de conexão Neon (postgresql+asyncpg://...)
#   REDIS_URL               ← string de conexão Upstash (redis://default:...@...:port)
#   ANTHROPIC_API_KEY
#   GROQ_API_KEY
#
# SEARXNG_URL NÃO é setada em prod — web_search retorna "indisponível".
