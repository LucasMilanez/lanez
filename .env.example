# ============================================
# Lanez — Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores.
# Variáveis sem valor padrão são OBRIGATÓRIAS.

# --- Microsoft Entra ID (OAuth 2.0) ---

# Application (client) ID registrado no Azure Portal
MICROSOFT_CLIENT_ID=

# Client secret gerado no Azure Portal (criar em "Credenciais do cliente" > "Adicionar certificado ou segredo")
MICROSOFT_CLIENT_SECRET=

# Directory (tenant) ID do Azure AD
MICROSOFT_TENANT_ID=

# URL de callback OAuth (padrão: http://localhost:8000/auth/callback)
MICROSOFT_REDIRECT_URI=http://localhost:8000/auth/callback

# URL pública onde a Graph API entregará notificações de webhook
# Em produção, deve ser um URL acessível publicamente (ex: ngrok em dev)
WEBHOOK_NOTIFICATION_URL=http://localhost:8000/webhooks/graph

# --- Banco de Dados ---

# Connection string PostgreSQL com asyncpg
DATABASE_URL=postgresql+asyncpg://lanez:lanez@localhost:5432/lanez

# --- Redis ---

# URL de conexão Redis
REDIS_URL=redis://localhost:6379/0

# --- Segurança ---

# Chave secreta para criptografia de tokens e assinatura de JWTs (OBRIGATÓRIA, sem valor padrão)
SECRET_KEY=

# Segredo compartilhado para validação de notificações de webhook da Microsoft (OBRIGATÓRIO, sem valor padrão)
WEBHOOK_CLIENT_STATE=

# --- CORS ---

# Origens permitidas separadas por vírgula (padrão: http://localhost:5173)
CORS_ORIGINS=http://localhost:5173

# --- SearXNG (busca web self-hosted) ---

# URL do serviço SearXNG para busca web (padrão: http://localhost:8080)
SEARXNG_URL=http://localhost:8080
