# ============================================
# Lanez — Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
# Variables without a default value are REQUIRED.
#
# Hosts: in Compose mode, hosts are 'db', 'redis', 'searxng'.
#        In manual mode (no Docker), replace with 'localhost'.

# --- Microsoft Entra ID (OAuth 2.0) ---

# Application (client) ID registered in the Azure Portal
MICROSOFT_CLIENT_ID=

# Client secret generated in the Azure Portal
MICROSOFT_CLIENT_SECRET=

# Directory (tenant) ID from Azure AD
MICROSOFT_TENANT_ID=

# OAuth callback URL
MICROSOFT_REDIRECT_URI=http://localhost:8000/auth/callback

# Public URL where the Graph API will deliver webhook notifications.
# In local dev, leave pointing to localhost (subscriptions will fail,
# but the app remains functional for manual use).
WEBHOOK_NOTIFICATION_URL=http://localhost:8000/webhooks/graph

# --- Security ---

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Shared secret for validating Microsoft webhook notifications
WEBHOOK_CLIENT_STATE=

# --- Database ---
# In compose the host is 'db'; in manual mode it's 'localhost'
DATABASE_URL=postgresql+asyncpg://lanez:lanez@db:5432/lanez

# --- Redis ---
# In compose the host is 'redis'; in manual mode it's 'localhost'
REDIS_URL=redis://redis:6379/0

# --- SearXNG ---
# In compose the host is 'searxng'; in manual mode it's 'localhost'
SEARXNG_URL=http://searxng:8080

# --- CORS ---
CORS_ORIGINS=http://localhost:5173

# --- Anthropic API (briefing generation) ---
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Briefing ---
BRIEFING_HISTORY_WINDOW_DAYS=90

# --- Groq Whisper (voice transcription) ---
# Optional — leaving blank disables voice transcription
GROQ_API_KEY=
GROQ_WHISPER_MODEL=whisper-large-v3-turbo
VOICE_MAX_AUDIO_BYTES=5242880
VOICE_MAX_DURATION_SECONDS=30

# --- Audit log ---
AUDIT_HISTORY_WINDOW_DAYS=30

# ============================================
# Production (Fly.io) — reference only
# ============================================
# The lines below are NOT read by the local .env.
# They document which env vars must be set on Fly.io
# via `fly secrets set NAME=value` or `flyctl secrets import < secrets.txt`.
#
# Non-secrets (already declared in fly.toml [env]):
#   BRIEFING_HISTORY_WINDOW_DAYS, AUDIT_HISTORY_WINDOW_DAYS,
#   GROQ_WHISPER_MODEL, VOICE_MAX_AUDIO_BYTES, VOICE_MAX_DURATION_SECONDS,
#   CORS_ORIGINS, MICROSOFT_REDIRECT_URI, WEBHOOK_NOTIFICATION_URL
#
# Secrets (require `fly secrets set`):
#   MICROSOFT_CLIENT_ID
#   MICROSOFT_CLIENT_SECRET
#   MICROSOFT_TENANT_ID
#   SECRET_KEY              ← generate a NEW key for prod (do not reuse dev)
#   WEBHOOK_CLIENT_STATE    ← generate a NEW value for prod
#   DATABASE_URL            ← Neon connection string (postgresql+asyncpg://...)
#   REDIS_URL               ← Upstash connection string (redis://default:...@...:port)
#   ANTHROPIC_API_KEY
#   GROQ_API_KEY
#
# SEARXNG_URL is NOT set in prod — web_search returns "unavailable".
